.form-card {
  display: flex;
  flex-direction: column;
}

.field-label {
  margin-top: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.field-input,
.field-picker,
.field-textarea {
  margin-top: 10rpx;
  background: #fff6f2;
  border-radius: 18rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.field-textarea {
  min-height: 180rpx;
}
